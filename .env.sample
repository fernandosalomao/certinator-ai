# =============================================================================
# Certinator AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# Azure AI Foundry project endpoint (required)
AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-id>

# Default model deployment name  (required)
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1
