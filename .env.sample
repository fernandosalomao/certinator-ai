# =============================================================================
# Certinator AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# =============================================================================
# LLM Provider Selection
# =============================================================================
# Choose your LLM provider: "azure", "github", or "local"
#   - azure:  Azure AI Foundry (default, requires FOUNDRY_PROJECT_ENDPOINT)
#   - github: GitHub Models (free tier, requires GITHUB_TOKEN)
#   - local:  FoundryLocal (runs locally, requires Foundry Local CLI)
LLM_PROVIDER=azure

# Legacy flag (USE_LOCAL_LLM=true is equivalent to LLM_PROVIDER=local)
# USE_LOCAL_LLM=false

# =============================================================================
# GitHub Models Configuration (only required when LLM_PROVIDER=github)
# =============================================================================
# GitHub Models provides free/low-cost access to GPT-4o, GPT-4o-mini, etc.
# Get your token: https://github.com/settings/tokens (needs "models:inference" scope)
# Model marketplace: https://github.com/marketplace/models
GITHUB_TOKEN=
GITHUB_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODEL_ID=gpt-4o-mini

# =============================================================================
# FoundryLocal Configuration (only required when LLM_PROVIDER=local)
# =============================================================================
# Model alias for FoundryLocal (e.g., phi-4-mini, qwen2.5-0.5b, phi-3.5-mini)
# Run `foundry model list` to see available models in your system.
FOUNDRY_LOCAL_MODEL_ALIAS=phi-4-mini

# =============================================================================
# Azure AI Foundry (only required when LLM_PROVIDER=azure)
# =============================================================================
# Azure AI Foundry project endpoint
FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-id>

# Default model deployment name
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1

# Per-agent model deployments (optional — override defaults from config.py)
# Lighter models for routing/verification, stronger for generation.
COORDINATOR_MODEL=gpt-4.1-mini
CERT_INFO_MODEL=gpt-4.1
STUDY_PLAN_MODEL=gpt-4.1
PRACTICE_MODEL=gpt-4.1
CRITIC_MODEL=gpt-4.1-mini

# OpenTelemetry tracing (optional — used if you override the default localhost)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317