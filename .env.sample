# =============================================================================
# Certinator AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# Azure AI Foundry project endpoint (required)
FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-id>

# Default model deployment name  (required)
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1

# Per-agent model deployments (optional — override defaults from config.py)
# Lighter models for routing/verification, stronger for generation.
COORDINATOR_MODEL=gpt-4.1-mini
CERT_INFO_MODEL=gpt-4.1
STUDY_PLAN_MODEL=gpt-4.1
PRACTICE_MODEL=gpt-4.1
CRITIC_MODEL=gpt-4.1-mini

# OpenTelemetry tracing (optional — used if you override the default localhost)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317