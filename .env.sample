# =============================================================================
# Certinator AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# =============================================================================
# LLM Provider Selection
# =============================================================================
# Choose your LLM provider: "azure", "github", or "local"
#   - azure:  Azure AI Foundry (default)
#             Requires: LLM_ENDPOINT + AZ CLI login ("az login")
#   - github: GitHub Models=
#             Requires: GITHUB_TOKEN
#   - local:  FoundryLocal (runs entirely on your machine)
#             Requires: Foundry Local CLI installed (no endpoint needed)

LLM_PROVIDER=azure
# LLM_PROVIDER=github
# LLM_PROVIDER=local

# =============================================================================
# Shared Endpoint (required for azure and github; not used for local)
# =============================================================================
# azure  → your Azure AI Foundry project endpoint
#          e.g. https://<name>.services.ai.azure.com/api/projects/<project-id>
# github → GitHub Models inference endpoint (use the default below)
#          e.g. https://models.github.ai/inference

LLM_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-id>
# LLM_ENDPOINT=https://models.github.ai/inference


# =============================================================================
# GitHub Models Configuration (only required when LLM_PROVIDER=github)
# =============================================================================
# Get your token: https://github.com/settings/tokens (needs "models:inference" scope)
# Model marketplace: https://github.com/marketplace/models

# GITHUB_TOKEN=


# =============================================================================
# Default model (used by all agents unless overridden below)
# =============================================================================
# The model name depends on the provider:
#   - azure:  Azure AI Foundry deployment name  e.g. gpt-4.1
#   - github: GitHub Models model ID            e.g. openai/gpt-4o
#   - local:  FoundryLocal model alias          e.g. qwen2.5-14b
#             Run "foundry model list" to see models available on your machine.

LLM_MODEL_DEFAULT=gpt-4.1
# LLM_MODEL_DEFAULT=openai/gpt-4o
# LLM_MODEL_DEFAULT=qwen2.5-14b


# =============================================================================
# Per-agent model overrides (optional)
# =============================================================================
# Each variable sets the model for a specific agent.
# If not set, the agent falls back to LLM_MODEL_DEFAULT.
# Use lighter models (e.g. gpt-4.1-mini) for routing/verification agents
# and stronger models (e.g. gpt-4.1) for generation agents.

# LLM_MODEL_COORDINATOR=gpt-4.1-mini
# LLM_MODEL_CERTIFICATION_INFO=gpt-4.1
# LLM_MODEL_CRITIC=gpt-4.1-mini
# LLM_MODEL_LEARNING_PATH_FETCHER=gpt-4.1
# LLM_MODEL_PRACTICE_QUESTIONS=gpt-4.1
# LLM_MODEL_STUDY_PLAN_GENERATOR=gpt-4.1

# =============================================================================
# Workflow Visualization (optional)
# =============================================================================
# When enabled, a workflow.svg diagram is generated at the project root on startup.
# Requires graphviz to be installed: https://graphviz.org/download/
#   macOS:  brew install graphviz
#   Debian: apt-get install graphviz

# GENERATE_WORKFLOW_VISUALIZATION=false

# =============================================================================
# Quiz / Practice Settings
# =============================================================================
# Number of practice questions generated per quiz session.

# DEFAULT_PRACTICE_QUESTIONS=10

# =============================================================================
# Backend Server
# =============================================================================
# Host and port for the AG-UI FastAPI server (Uvicorn).
# The frontend connects to this address to reach the backend.
#   - Use 127.0.0.1 for local development (default)
#   - Use 0.0.0.0 to listen on all interfaces (e.g. Docker / production)
# AGUI_HOST and AGUI_PORT must also be set in the frontend environment
# (frontend/.env.local) so the Next.js API route can reach the backend.

# AGUI_HOST=127.0.0.1
# AGUI_PORT=8000

# =============================================================================
# OpenTelemetry tracing
# =============================================================================

# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=certinator-ai
ENABLE_INSTRUMENTATION=true 
ENABLE_SENSITIVE_DATA=true # Capture prompts and completions
# ENABLE_CONSOLE_EXPORTERS=true
# VS_CODE_EXTENSION_PORT=4317 # AI Toolkit gRPC port