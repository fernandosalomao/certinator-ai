// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
  "name": "Certinator AI",
  // Use Python 3.12 (stable, compatible with all dependencies)
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20",
      "pnpm": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "njpwerner.autodocstring",
        "charliermarsh.ruff",
        "teamsdevapp.vscode-ai-foundry",
        "ms-windows-ai-studio.windows-ai-studio",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/certinator-ai/.venv/bin/python"
      }
    }
  },

  // Forward ports for backend (8087) and frontend (3000)
  "forwardPorts": [3000, 8087],
  "portsAttributes": {
    "3000": { "label": "Frontend (Next.js)", "onAutoForward": "openBrowser" },
    "8087": { "label": "Backend (Agent Server)" }
  },

  // Install all dependencies after container creation
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  // Environment variables
  "remoteEnv": {
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
